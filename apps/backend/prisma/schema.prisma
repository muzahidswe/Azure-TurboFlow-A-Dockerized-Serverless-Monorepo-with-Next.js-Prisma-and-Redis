generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") 
}

enum Role {
  User
  Admin
}

enum Status {
  Inactive
  Active
  Blocked
}

model User {
  id        Int    @id @default(autoincrement())
  firstname String
  lastname  String
  phone     String
  city      String
  email     String @unique
  password  String

  role      Role   @default(User)
  status    Status @default(Active)

  createdAt DateTime @default(now())   // auto set
  updatedAt DateTime @updatedAt        // auto update
}